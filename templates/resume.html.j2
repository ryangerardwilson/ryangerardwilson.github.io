<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ basics.name }} Resume</title>
  <style>
{{ css }}
  </style>
</head>
<body>
  {% macro render_section(section, basics, avatar_src) -%}
    {% if section.kind == "identity" %}
    <section class="identity">
      {% if avatar_src %}
      <img class="avatar" src="{{ avatar_src }}" alt="{{ basics.name }} avatar">
      {% endif %}
      <h1>{{ basics.name }}</h1>
      <p class="headline">{{ basics.headline }}</p>
    </section>
    {% elif section.kind == "contact" %}
    <section class="section">
      {% if section.title %}
      <h2>{{ section.title }}</h2>
      {% endif %}
      <ul class="contact-list">
        {% for item in section["items"] %}
        <li>
          <span class="contact-label">{{ item.label }}</span>
          {% if item.href %}
          <a href="{{ item.href }}">{{ item.display }}</a>
          {% else %}
          <span>{{ item.display }}</span>
          {% endif %}
        </li>
        {% endfor %}
      </ul>
    </section>
    {% elif section.kind == "education" %}
    <section class="section">
      {% if section.title %}
      <h2>{{ section.title }}</h2>
      {% endif %}
      <div class="stack">
        {% for item in section["items"] %}
        <article class="education-item">
          <header>{{ item.credential }}</header>
          <p>{{ item.institution }}</p>
          <small>{{ item.year }}</small>
        </article>
        {% endfor %}
      </div>
    </section>
    {% elif section.kind == "skills" %}
    <section class="section">
      {% if section.title %}
      <h2>{{ section.title }}</h2>
      {% endif %}
      <div class="stack">
        {% for group in section["items"] %}
        <article class="skill-group">
          <header>{{ group.label }}</header>
          <p>{{ group["items"] | join(", ") }}</p>
        </article>
        {% endfor %}
      </div>
    </section>
    {% elif section.kind == "profile" %}
    <section class="section hero-summary">
      {% if section.title %}
      <h2>{{ section.title }}</h2>
      {% endif %}
      <p>{{ section.text }}</p>
    </section>
    {% elif section.kind == "experience" %}
    <section class="section">
      {% if section.title %}
      <h2>{{ section.title }}</h2>
      {% endif %}
      <div class="stack">
        {% for item in section["items"] %}
        <article class="experience-item">
          <div class="experience-header">
            <div>
              <header>{{ item.role }}{% if item.company %}, {{ item.company }}{% endif %}</header>
              {% if item.location %}
              <p class="meta">{{ item.location }}</p>
              {% endif %}
            </div>
            <span class="date-range">{{ item.dateRange }}</span>
          </div>
          <ul>
            {% for bullet in item.bullets %}
            <li>{{ bullet }}</li>
            {% endfor %}
          </ul>
        </article>
        {% endfor %}
      </div>
    </section>
    {% elif section.kind == "projects" %}
    <section class="section">
      {% if section.title %}
      <h2>{{ section.title }}</h2>
      {% endif %}
      {% if section.subtitle %}
      <p class="section-subtitle">{{ section.subtitle }}</p>
      {% endif %}
      <div class="stack">
        {% for item in section["items"] %}
        <article class="project-item">
          <div class="project-header">
            {% if item.href %}
            <header>{{ item.name }} <a class="project-link" href="{{ item.href }}">[GitHub: {{ item.href }}]</a></header>
            {% else %}
            <header>{{ item.name }}</header>
            {% endif %}
            {% if item.launchDate %}
            <p class="project-launch-date">Launch: {{ item.launchDate }}</p>
            {% endif %}
          </div>
          <ul class="project-points">
            <li><strong>Why:</strong> {{ item.why }}</li>
            <li><strong>What:</strong> {{ item.what }}</li>
          </ul>
        </article>
        {% endfor %}
      </div>
    </section>
    {% elif section.kind == "certifications" %}
    <section class="section">
      {% if section.title %}
      <h2>{{ section.title }}</h2>
      {% endif %}
      <ul class="certifications">
        {% for item in section["items"] %}
        <li>{{ item }}</li>
        {% endfor %}
      </ul>
    </section>
    {% endif %}
  {%- endmacro %}

  <main class="resume">
    {% for page in pages %}
    <section class="page">
      <aside class="sidebar">
        {% for section in page.left_sections %}
        {{ render_section(section, basics, avatar_src) }}
        {% endfor %}
      </aside>

      <section class="main-column">
        {% for section in page.right_sections %}
        {{ render_section(section, basics, avatar_src) }}
        {% endfor %}
      </section>
    </section>
    {% endfor %}
  </main>
</body>
</html>
